    { "source": "/go/th-shigyo",  "destination": "https://shigyo.pathflow.org/?utm_source=threads&utm_medium=social&utm_campaign=shigyo", "permanent": false },
    { "source": "/go/ht-shigyo",  "destination": "https://shigyo.pathflow.org/?utm_source=hatena&utm_medium=social&utm_campaign=shigyo", "permanent": false },
