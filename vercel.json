    { "source": "/go/fb-main",    "destination": "https://main.pathflow.org/?utm_source=facebook&utm_medium=social&utm_campaign=main", "permanent": false },
    { "source": "/go/x-main",     "destination": "https://main.pathflow.org/?utm_source=x&utm_medium=social&utm_campaign=main", "permanent": false },
    { "source": "/go/th-main",    "destination": "https://main.pathflow.org/?utm_source=threads&utm_medium=social&utm_campaign=main", "permanent": false },
    { "source": "/go/ht-main",    "destination": "https://main.pathflow.org/?utm_source=hatena&utm_medium=social&utm_campaign=main", "permanent": false },
    { "source": "/go/fb-shigyo",  "destination": "https://shigyo.pathflow.org/?utm_source=facebook&utm_medium=social&utm_campaign=shigyo", "permanent": false },
